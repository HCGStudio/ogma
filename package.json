{
  "name": "ogma-workspace",
  "private": true,
  "packageManager": "yarn@4.9.2",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -A run build",
    "dev": "yarn workspace @hcgstudio/ogma dev",
    "ogma": "yarn workspace @hcgstudio/ogma ogma",
    "typecheck": "yarn workspaces foreach -A run typecheck"
  }
}
